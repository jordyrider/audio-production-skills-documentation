{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool",
  "description": "JSON schema for tool model markdown files in the skills knowledge base",
  "type": "object",
  "required": ["type", "status", "provider", "model"],
  "properties": {
    "type": {
      "type": "string",
      "const": "tool",
      "description": "File type identifier"
    },
    "status": {
      "type": "string",
      "enum": ["stub", "draft", "validated"],
      "description": "Maturity level of this file's content"
    },
    "provider": {
      "type": "string",
      "description": "Provider name (e.g. MiniMax, ElevenLabs)"
    },
    "model": {
      "type": "string",
      "description": "Model name or version identifier"
    },
    "parameters": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          },
          "description": "Model parameters as key-value pairs"
        },
        { "type": "null" }
      ],
      "description": "Available parameters for this model"
    },
    "stable_styles": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["style", "behavior"],
            "properties": {
              "style": { "type": "string", "description": "Style name or genre" },
              "behavior": { "type": "string", "description": "How the model behaves with this style" }
            },
            "additionalProperties": false
          }
        },
        { "type": "null" }
      ],
      "description": "Styles and genres this model handles reliably"
    },
    "gotchas": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Known issues, quirks, or traps when using this model"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "status": { "const": "stub" } },
    "required": ["status"]
  },
  "then": {},
  "else": {
    "properties": {
      "parameters": {
        "type": "object"
      },
      "stable_styles": {
        "type": "array",
        "minItems": 1
      },
      "gotchas": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      }
    }
  }
}
