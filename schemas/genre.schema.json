{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Genre",
  "description": "JSON schema for genre sub-genre markdown files in the skills knowledge base",
  "type": "object",
  "required": ["type", "status", "parent"],
  "properties": {
    "type": {
      "type": "string",
      "const": "genre",
      "description": "File type identifier"
    },
    "status": {
      "type": "string",
      "enum": ["stub", "draft", "validated"],
      "description": "Maturity level of this file's content"
    },
    "parent": {
      "type": ["string", "null"],
      "description": "Parent genre ID from the genre index.yaml. Null allowed when status is stub."
    },
    "mood": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Mood descriptors for this genre"
    },
    "bpm_range": {
      "oneOf": [
        {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ],
      "description": "Typical BPM range for this genre"
    },
    "tags": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Searchable tags for this genre"
    },
    "instrumentation": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Typical instruments used in this genre"
    },
    "effects": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Typical audio effects used in this genre"
    },
    "canva_use_cases": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Canva design contexts where this genre fits"
    },
    "prompting_rules": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Rules and guidelines for prompting this genre effectively"
    },
    "validated_patterns": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["prompt", "output"],
            "properties": {
              "prompt": { "type": "string" },
              "output": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        { "type": "null" }
      ],
      "description": "Prompt/output pairs that have been validated as working well"
    },
    "known_limitations": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Known issues or limitations with this genre"
    },
    "still_testing": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Patterns or approaches currently under evaluation"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "status": { "const": "stub" } },
    "required": ["status"]
  },
  "then": {},
  "else": {
    "properties": {
      "parent": { "type": "string" },
      "mood": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "instrumentation": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "canva_use_cases": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "prompting_rules": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      }
    }
  }
}
