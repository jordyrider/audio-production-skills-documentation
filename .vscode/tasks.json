{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate Frontmatter",
      "type": "shell",
      "command": "node scripts/validate-frontmatter.js",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "frontmatter-validator",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}
